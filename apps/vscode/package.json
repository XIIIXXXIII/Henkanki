{
  "name": "henkanki-vscode",
  "displayName": "Henkanki",
  "description": "Local-first file conversion extension for VS Code. Convert files between formats without leaving your editor.",
  "version": "0.3.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:henkanki.convert",
    "onCommand:henkanki.convertFile",
    "onCommand:henkanki.showFormats"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "henkanki.convert",
        "title": "Henkanki: Convert Selection"
      },
      {
        "command": "henkanki.convertFile",
        "title": "Henkanki: Convert File"
      },
      {
        "command": "henkanki.showFormats",
        "title": "Henkanki: Show Supported Formats"
      },
      {
        "command": "henkanki.convertClipboard",
        "title": "Henkanki: Convert Clipboard Content"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "henkanki.convert",
          "group": "henkanki",
          "when": "editorTextFocus"
        }
      ],
      "explorer/context": [
        {
          "command": "henkanki.convertFile",
          "group": "henkanki",
          "when": "explorerResourceIsFile"
        }
      ],
      "commandPalette": [
        {
          "command": "henkanki.convert",
          "when": "editorTextFocus"
        },
        {
          "command": "henkanki.convertFile",
          "when": "explorerResourceIsFile"
        },
        {
          "command": "henkanki.showFormats"
        },
        {
          "command": "henkanki.convertClipboard"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "node esbuild.config.mjs",
    "watch": "nodemon --watch src --ext js --exec \"npm run compile\"",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext .js",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/test-web": "^0.0.17",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "nodemon": "^3.0.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "vscode": "^1.1.34"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/XIIIXXXIII/Henkanki"
  },
  "bugs": {
    "url": "https://github.com/XIIIXXXIII/Henkanki/issues"
  },
  "homepage": "https://github.com/XIIIXXXIII/Henkanki#readme"
}
